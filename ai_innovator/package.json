{
  "name": "medicare-ai-root",
  "version": "1.0.0",
  "description": "MedicareAI Unified Platform",
  "scripts": {
    "dev:ml": "cd ml_service && ./venv/bin/python app.py",
    "dev:backend": "cd backend && npm run build && node dist/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:ml\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}